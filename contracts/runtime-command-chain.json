  "ordering_note": "KESHAV is invoked only after Raj returns a trace-preserving typed product error; successful product responses record a no-call skip. The supplied KESHAV /analyze wrapper internally runs its bundled TANTRA chain but returns only the diagnosis contract, so Mitra records no independent RAJYA, Sarathi, Core, or internal Bucket authority claim. Karma must accept before PRANA forwarding.",
  "execution_contract": {
    "endpoint": "POST /api/v1/ecosystem/execute",
    "mode": "strict-published-contracts",
    "embedded_fallback": false,
    "checkpoint_model": "one immutable response-bearing checkpoint per stage"
  },
