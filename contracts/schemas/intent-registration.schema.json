{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.mitra.local/intent-registration/1.0.0",
  "title": "Mitra Intent Registration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registration_id",
    "product_id",
    "product_name",
    "product_version",
    "attachment_state",
    "registered_at",
    "capability_id",
    "capability_description",
    "capability_metadata",
    "context_scopes",
    "intent_id",
    "description",
    "input_schema",
    "response_schema",
    "dispatch",
    "metadata"
  ],
  "properties": {
    "registration_id": {"type": "string", "minLength": 5},
    "product_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "product_name": {"type": "string", "minLength": 3},
    "product_version": {"type": "string", "minLength": 5},
    "attachment_state": {"enum": ["ATTACHED", "DEGRADED"]},
    "registered_at": {"type": "string", "minLength": 1},
    "capability_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "capability_description": {"type": "string", "minLength": 3},
    "capability_metadata": {"type": "object"},
    "context_scopes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": ["session", "workspace", "product", "handoff"]
      }
    },
    "intent_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]{2,95}$"
    },
    "description": {"type": "string", "minLength": 3},
    "input_schema": {"type": "object"},
    "response_schema": {"type": "object"},
    "dispatch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "endpoint",
        "timeout_seconds",
        "options"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{1,31}$"
        },
        "endpoint": {"type": "string", "minLength": 1},
        "timeout_seconds": {
          "type": ["number", "null"],
          "exclusiveMinimum": 0,
          "maximum": 120
        },
        "options": {"type": "object"}
      }
    },
    "metadata": {"type": "object"}
  }
}
