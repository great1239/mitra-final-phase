{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mitra.local/schemas/source-scope-catalog.schema.json",
  "title": "Source Scope Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_version",
    "runtime_version",
    "compatibility_version",
    "catalog_version",
    "purpose",
    "selection_policy",
    "previous_submissions",
    "runtime_imports",
    "external_systems",
    "future_product_intake"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "contract_version": {"const": "1.0.0"},
    "runtime_version": {"const": "1.0.0"},
    "compatibility_version": {"const": "mitra-companion-1"},
    "catalog_version": {"type": "string", "minLength": 1},
    "purpose": {"type": "string", "minLength": 1},
    "selection_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["import_when", "externalize_when", "never_import"],
      "properties": {
        "import_when": {"type": "array", "items": {"type": "string"}},
        "externalize_when": {"type": "array", "items": {"type": "string"}},
        "never_import": {"type": "array", "items": {"type": "string"}}
      }
    },
    "previous_submissions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/previousSubmission"}
    },
    "runtime_imports": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/runtimeImport"}
    },
    "external_systems": {
      "type": "array",
      "items": {"$ref": "#/$defs/externalSystem"}
    },
    "future_product_intake": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "previousSubmission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "submission_id",
        "local_folder",
        "useful_systems",
        "copied_or_mapped_features",
        "externalized_systems"
      ],
      "properties": {
        "submission_id": {"type": "string", "minLength": 1},
        "local_folder": {"type": "string", "minLength": 1},
        "useful_systems": {
          "type": "array",
          "items": {"type": "string"}
        },
        "copied_or_mapped_features": {
          "type": "array",
          "items": {"type": "string"}
        },
        "externalized_systems": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "runtimeImport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "feature_id",
        "source_submission_ids",
        "implemented_in",
        "runtime_surface",
        "used_for",
        "boundary"
      ],
      "properties": {
        "feature_id": {"type": "string", "minLength": 1},
        "source_submission_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "implemented_in": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "runtime_surface": {"type": "string", "minLength": 1},
        "used_for": {"type": "array", "items": {"type": "string"}},
        "boundary": {
          "enum": [
            "internal-runtime",
            "contract-only",
            "external-capability"
          ]
        }
      }
    },
    "externalSystem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system_id",
        "source_submission_ids",
        "runtime_relationship",
        "integration_method",
        "not_copied_reason"
      ],
      "properties": {
        "system_id": {"type": "string", "minLength": 1},
        "source_submission_ids": {
          "type": "array",
          "items": {"type": "string"}
        },
        "runtime_relationship": {"type": "string", "minLength": 1},
        "integration_method": {"type": "string", "minLength": 1},
        "not_copied_reason": {"type": "string", "minLength": 1}
      }
    }
  }
}
