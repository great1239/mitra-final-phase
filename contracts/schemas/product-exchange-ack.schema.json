{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.mitra.local/product-exchange-ack/1.0.0",
  "title": "Product Exchange Acknowledgement Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_version",
    "runtime_version",
    "compatibility_version",
    "product_id"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "contract_version": {"const": "1.0.0"},
    "runtime_version": {"const": "1.0.0"},
    "compatibility_version": {"const": "mitra-companion-1"},
    "product_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "status": {
      "enum": ["RECEIVED", "CONSUMED", "REJECTED"],
      "default": "RECEIVED"
    },
    "note": {"type": ["string", "null"], "maxLength": 500},
    "metadata": {"type": "object"}
  }
}
