{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.mitra.local/product-attachment/1.0.0",
  "title": "Mitra Product Attachment Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "product_id",
    "display_name",
    "product_version",
    "contract_version",
    "attachment_mode",
    "capabilities"
  ],
  "properties": {
    "product_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "display_name": {"type": "string", "minLength": 3, "maxLength": 120},
    "product_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
    },
    "contract_version": {"const": "1.0.0"},
    "attachment_mode": {
      "enum": ["standalone", "embedded", "remote", "simulated"]
    },
    "base_url": {"type": ["string", "null"], "format": "uri"},
    "health_endpoint": {"type": ["string", "null"]},
    "metadata": {"type": "object"},
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "capability_id",
          "description",
          "context_scopes",
          "intents"
        ],
        "properties": {
          "capability_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{2,63}$"
          },
          "description": {"type": "string", "minLength": 3},
          "context_scopes": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "enum": ["session", "workspace", "product", "handoff"]
            }
          },
          "metadata": {"type": "object"},
          "intents": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "intent_id",
                "description",
                "input_schema",
                "dispatch"
              ],
              "properties": {
                "intent_id": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_.-]{2,95}$"
                },
                "description": {"type": "string", "minLength": 3},
                "input_schema": {"type": "object"},
                "response_schema": {
                  "type": "object",
                  "description": "JSON Schema describing the response object returned by this intent's dispatch target. Older manifests may omit this field; Mitra treats omission as {\"type\":\"object\"}."
                },
                "metadata": {"type": "object"},
                "dispatch": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["mode", "endpoint"],
                  "properties": {
                    "mode": {
                      "type": "string",
                      "pattern": "^[a-z][a-z0-9-]{1,31}$"
                    },
                    "endpoint": {"type": "string", "minLength": 1},
                    "timeout_seconds": {
                      "type": ["number", "null"],
                      "exclusiveMinimum": 0,
                      "maximum": 120
                    },
                    "options": {"type": "object"}
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
