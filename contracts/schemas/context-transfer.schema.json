{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.mitra.local/context-transfer/1.0.0",
  "title": "Companion Context Transfer Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_version",
    "runtime_version",
    "compatibility_version",
    "target_workspace_id",
    "portable_context"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "contract_version": {"const": "1.0.0"},
    "runtime_version": {"const": "1.0.0"},
    "compatibility_version": {"const": "mitra-companion-1"},
    "target_workspace_id": {"type": "string", "minLength": 1},
    "target_product_id": {"type": ["string", "null"]},
    "portable_context": {"type": "object"},
    "metadata": {"type": "object"}
  }
}

