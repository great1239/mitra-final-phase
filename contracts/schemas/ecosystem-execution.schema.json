{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bhiv.example/contracts/mitra/ecosystem-execution.schema.json",
  "title": "TANTRA Ecosystem Execution Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_version",
    "runtime_version",
    "compatibility_version",
    "message"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "contract_version": {"const": "1.0.0"},
    "runtime_version": {"const": "1.0.0"},
    "compatibility_version": {"const": "mitra-companion-1"},
    "session_id": {"type": ["string", "null"], "minLength": 1},
    "actor_id": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 200
    },
    "client_type": {
      "enum": ["standalone", "embedded", "mobile", "xr", "robotics"],
      "default": "standalone"
    },
    "workspace_id": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 200
    },
    "product_id": {
      "type": ["string", "null"],
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "capability_id": {
      "type": ["string", "null"],
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "message": {"type": "string", "minLength": 1, "maxLength": 4000},
    "assignment": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 12000
    },
    "payload": {"type": "object", "default": {}},
    "idempotency_key": {
      "type": ["string", "null"],
      "minLength": 8,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "metadata": {"type": "object", "default": {}}
  },
  "allOf": [
    {
      "if": {
        "properties": {"session_id": {"type": "null"}}
      },
      "then": {"required": ["actor_id", "workspace_id"]}
    }
  ]
}
