{
  "product_id": "setu-bridge",
  "display_name": "SETU Bridge",
  "product_version": "1.0.0",
  "contract_version": "1.0.0",
  "attachment_mode": "simulated",
  "capabilities": [
    {
      "capability_id": "handoff-bridge",
      "description": "Bridges portable runtime handoff packets to downstream BHIV systems through published envelopes.",
      "context_scopes": ["session", "workspace", "handoff"],
      "metadata": {
        "bhiv_system": true,
        "convergence_role": "handoff-bridge",
        "integration_surface": "published-manifest"
      },
      "intents": [
        {
          "intent_id": "setu.forward-handoff",
          "description": "Forward a replay or proof handoff packet to an external BHIV consumer.",
          "input_schema": {
            "type": "object",
            "additionalProperties": false,
            "required": ["handoff_type", "subject_id"],
            "properties": {
              "handoff_type": {
                "type": "string",
                "enum": ["proof", "replay", "depository"]
              },
              "subject_id": {"type": "string", "minLength": 1},
              "target_system": {"type": "string"}
            }
          },
          "response_schema": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "accepted": {"type": "boolean"},
              "status": {"type": "string"},
              "subject_id": {"type": "string"},
              "forwarded_to": {"type": "string"}
            }
          },
          "dispatch": {
            "mode": "loopback",
            "endpoint": "loopback://setu/handoffs/forward"
          },
          "metadata": {
            "owned_by_product": true,
            "consumes": ["proof_bundle", "replay_package"]
          }
        }
      ]
    }
  ],
  "metadata": {
    "bhiv_product": true,
    "bhiv_product_name": "SETU",
    "business_logic_owner": "setu-bridge",
    "integration_direction": "convergence-consumer",
    "integration_surface": "published-manifest"
  }
}
