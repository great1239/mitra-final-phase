{
  "product_id": "uniguru-ai",
  "display_name": "UniGuru AI",
  "product_version": "1.0.0",
  "contract_version": "1.0.0",
  "attachment_mode": "remote",
  "base_url": "http://127.0.0.1:8010",
  "health_endpoint": "/health",
  "capabilities": [
    {
      "capability_id": "constitutional-learning",
      "description": "Executes governed curriculum queries through the UniGuru runtime API.",
      "context_scopes": ["session", "workspace", "product"],
      "metadata": {
        "product_folder": "uniguru_ai",
        "interface_file": "uniguru_ai/uniguru_v2-main-main/backend/service/uniguru_runtime_api.py",
        "health_file": "uniguru_ai/backend/service/api.py",
        "health_route": "GET /health",
        "route": "POST /runtime/execute"
      },
      "intents": [
        {
          "intent_id": "uniguru.execute-query",
          "description": "Run a governed curriculum query and return UniGuru runtime evidence.",
          "input_schema": {
            "type": "object",
            "additionalProperties": false,
            "required": ["query"],
            "properties": {
              "query": {
                "type": "string",
                "minLength": 1,
                "maxLength": 2000
              },
              "grade": {
                "type": "integer",
                "minimum": 1,
                "maximum": 10
              },
              "medium": {
                "type": "string",
                "minLength": 1
              },
              "subject": {
                "type": "string",
                "minLength": 1
              },
              "emit_proof": {
                "type": "boolean"
              }
            }
          },
          "response_schema": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "status": {"type": "string"},
              "answer": {"type": ["string", "object", "array", "null"]},
              "evidence": {"type": ["object", "array", "null"]},
              "trace_id": {"type": "string"}
            }
          },
          "dispatch": {
            "mode": "http",
            "endpoint": "/runtime/execute",
            "timeout_seconds": 30,
            "options": {
              "request_body": "payload"
            }
          },
          "metadata": {
            "owned_by_product": true,
            "adapter_contract": "native-http-payload"
          }
        }
      ]
    }
  ],
  "metadata": {
    "bhiv_product": true,
    "bhiv_product_name": "UniGuru",
    "business_logic_owner": "uniguru_ai",
    "integration_direction": "backward",
    "health_monitoring": "GET /health",
    "integration_surface": "published-manifest"
  }
}
