{
  "product_id": "nova-operations",
  "display_name": "Nova Operations",
  "product_version": "1.0.0",
  "contract_version": "1.0.0",
  "attachment_mode": "standalone",
  "health_endpoint": "/health",
  "capabilities": [
    {
      "capability_id": "operations-navigation",
      "description": "Receives explicit operational navigation requests.",
      "context_scopes": ["session", "workspace", "product", "handoff"],
      "intents": [
        {
          "intent_id": "operations.open-run",
          "description": "Open an operational run identified by the caller.",
          "input_schema": {
            "type": "object",
            "required": ["run_id"]
          },
          "dispatch": {
            "mode": "loopback",
            "endpoint": "loopback://nova/open-run"
          }
        },
        {
          "intent_id": "operations.show-status",
          "description": "Show status for a supplied operational resource.",
          "input_schema": {
            "type": "object",
            "required": ["resource_id"]
          },
          "dispatch": {
            "mode": "loopback",
            "endpoint": "loopback://nova/show-status"
          }
        }
      ]
    }
  ],
  "metadata": {
    "example": true,
    "business_logic_owner": "nova-operations"
  }
}

