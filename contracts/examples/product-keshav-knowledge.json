{
  "product_id": "keshav-knowledge",
  "display_name": "KESHAV Knowledge",
  "product_version": "1.0.0",
  "contract_version": "1.0.0",
  "attachment_mode": "simulated",
  "capabilities": [
    {
      "capability_id": "knowledge-reference",
      "description": "Returns external knowledge references while Mitra keeps only routing and context continuity.",
      "context_scopes": ["session", "workspace"],
      "metadata": {
        "bhiv_system": true,
        "convergence_role": "knowledge-reference-provider",
        "integration_surface": "published-manifest"
      },
      "intents": [
        {
          "intent_id": "keshav.retrieve-reference",
          "description": "Retrieve a product-owned knowledge reference for a query.",
          "input_schema": {
            "type": "object",
            "additionalProperties": false,
            "required": ["query"],
            "properties": {
              "query": {"type": "string", "minLength": 1},
              "domain": {"type": "string"}
            }
          },
          "response_schema": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "accepted": {"type": "boolean"},
              "status": {"type": "string"},
              "references": {"type": ["array", "object", "null"]},
              "source_count": {"type": "integer", "minimum": 0}
            }
          },
          "dispatch": {
            "mode": "loopback",
            "endpoint": "loopback://keshav/references/retrieve"
          },
          "metadata": {
            "owned_by_product": true,
            "boundary": "knowledge remains product-owned"
          }
        }
      ]
    }
  ],
  "metadata": {
    "bhiv_product": true,
    "bhiv_product_name": "KESHAV",
    "business_logic_owner": "keshav-knowledge",
    "integration_direction": "convergence-consumer",
    "integration_surface": "published-manifest"
  }
}
