### Product self-attachment through the published Companion Runtime API.
### No Companion Runtime code change is required for this product.

POST http://localhost:8090/api/v1/attachments
Content-Type: application/json

{
  "schema_version": "1.0.0",
  "contract_version": "1.0.0",
  "runtime_version": "1.0.0",
  "compatibility_version": "mitra-companion-1",
  "manifest": {
    "product_id": "echo-lab",
    "display_name": "Echo Lab",
    "product_version": "1.0.0",
    "contract_version": "1.0.0",
    "attachment_mode": "embedded",
    "base_url": null,
    "health_endpoint": null,
    "metadata": {
      "example": true,
      "purpose": "Demonstrates self-attachment through the public manifest contract"
    },
    "capabilities": [
      {
        "capability_id": "echo-observation",
        "description": "Echoes the supplied payload through a generic loopback adapter",
        "context_scopes": ["session", "workspace"],
        "metadata": {
          "owned_by_product": true
        },
        "intents": [
          {
            "intent_id": "echo.repeat",
            "description": "Return the supplied message and declared context scopes",
            "input_schema": {
              "type": "object",
              "additionalProperties": false,
              "required": ["message"],
              "properties": {
                "message": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "dispatch": {
              "mode": "loopback",
              "endpoint": "loopback://echo-lab/repeat"
            },
            "metadata": {
              "example": true
            }
          }
        ]
      }
    ]
  }
}

### Discover the product's registered intent.

GET http://localhost:8090/api/v1/intents?product_id=echo-lab&intent_id=echo.repeat

### Dispatch using only the published intent identifier and JSON payload.

POST http://localhost:8090/api/v1/intents/dispatch
Content-Type: application/json

{
  "schema_version": "1.0.0",
  "contract_version": "1.0.0",
  "runtime_version": "1.0.0",
  "compatibility_version": "mitra-companion-1",
  "session_id": "replace-with-session-id",
  "intent_id": "echo.repeat",
  "product_id": "echo-lab",
  "payload": {
    "message": "hello from an attached product"
  }
}
