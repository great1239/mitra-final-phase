{
  "product_id": "trade-bot-main",
  "display_name": "Samruddhi Forward Integration",
  "product_version": "1.0.0",
  "contract_version": "1.0.0",
  "attachment_mode": "remote",
  "base_url": "http://127.0.0.1:8000",
  "health_endpoint": "/tools/health",
  "capabilities": [
    {
      "capability_id": "market-prediction",
      "description": "Generates stock prediction outputs through the Trade Bot MCP API.",
      "context_scopes": ["session", "workspace", "product"],
      "metadata": {
        "product_folder": "trade-bot-main",
        "interface_file": "trade-bot-main/backend/api_server.py",
        "adapter_file": "trade-bot-main/backend/core/mcp_adapter.py",
        "route": "POST /tools/predict"
      },
      "intents": [
        {
          "intent_id": "tradebot.predict",
          "description": "Generate predictions for one or more market symbols.",
          "input_schema": {
            "type": "object",
            "additionalProperties": false,
            "required": ["symbols"],
            "properties": {
              "symbols": {
                "type": "array",
                "minItems": 1,
                "maxItems": 50,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 20
                }
              },
              "horizon": {
                "type": "string",
                "enum": ["intraday", "short", "long"]
              },
              "risk_profile": {
                "type": "string",
                "enum": ["low", "moderate", "high"]
              },
              "stop_loss_pct": {
                "type": "number",
                "minimum": 0.1,
                "maximum": 50.0
              },
              "capital_risk_pct": {
                "type": "number",
                "minimum": 0.1,
                "maximum": 100.0
              },
              "drawdown_limit_pct": {
                "type": "number",
                "minimum": 0.1,
                "maximum": 100.0
              }
            }
          },
          "dispatch": {
            "mode": "http",
            "endpoint": "/tools/predict",
            "timeout_seconds": 45,
            "options": {
              "request_body": "payload"
            }
          },
          "metadata": {
            "owned_by_product": true,
            "adapter_contract": "native-http-payload"
          }
        }
      ]
    },
    {
      "capability_id": "risk-analysis",
      "description": "Runs symbol-level horizon analysis through the Trade Bot MCP API.",
      "context_scopes": ["session", "workspace", "product"],
      "metadata": {
        "product_folder": "trade-bot-main",
        "interface_file": "trade-bot-main/backend/api_server.py",
        "adapter_file": "trade-bot-main/backend/core/mcp_adapter.py",
        "route": "POST /tools/analyze"
      },
      "intents": [
        {
          "intent_id": "tradebot.analyze",
          "description": "Analyze a symbol across one or more horizons with risk parameters.",
          "input_schema": {
            "type": "object",
            "additionalProperties": false,
            "required": ["symbol"],
            "properties": {
              "symbol": {
                "type": "string",
                "minLength": 1,
                "maxLength": 20
              },
              "horizons": {
                "type": "array",
                "minItems": 1,
                "maxItems": 3,
                "items": {
                  "type": "string",
                  "enum": ["intraday", "short", "long"]
                }
              },
              "stop_loss_pct": {
                "type": "number",
                "minimum": 0.1,
                "maximum": 50.0
              },
              "capital_risk_pct": {
                "type": "number",
                "minimum": 0.1,
                "maximum": 100.0
              },
              "drawdown_limit_pct": {
                "type": "number",
                "minimum": 0.1,
                "maximum": 100.0
              }
            }
          },
          "dispatch": {
            "mode": "http",
            "endpoint": "/tools/analyze",
            "timeout_seconds": 45,
            "options": {
              "request_body": "payload"
            }
          },
          "metadata": {
            "owned_by_product": true,
            "adapter_contract": "native-http-payload"
          }
        }
      ]
    }
  ],
  "metadata": {
    "bhiv_product": true,
    "bhiv_product_name": "Samruddhi",
    "business_logic_owner": "trade-bot-main",
    "integration_direction": "forward",
    "health_monitoring": "GET /tools/health",
    "integration_surface": "published-manifest"
  }
}
