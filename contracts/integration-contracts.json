{
  "schema_version": "1.0.0",
  "contract_version": "1.0.0",
  "runtime_version": "1.0.0",
  "compatibility_version": "mitra-companion-1",
  "interface_family": "companion-runtime-foundations",
  "stability": {
    "breaking_changes": "require a new major contract_version",
    "non_breaking_changes": [
      "new optional response fields",
      "new adapter modes registered outside runtime implementation",
      "new product manifests conforming to the published schema"
    ],
    "version_fields_required_on_mutations": [
      "schema_version",
      "contract_version",
      "runtime_version",
      "compatibility_version"
    ]
  },
  "api": {
    "openapi": "contracts/api/companion-runtime.openapi.yaml",
    "version": "1.0.0",
    "paths": [
      "/health",
      "/metrics",
      "/ready",
      "/api/v1/runtime/status",
      "/api/v1/runtime/startup",
      "/api/v1/runtime/restart",
      "/api/v1/runtime/recovery",
      "/api/v1/runtime/config",
      "/api/v1/runtime/secrets",
      "/api/v1/runtime/instances",
      "/api/v1/runtime/instances/reconcile",
      "/api/v1/runtime/instances/{instance_id}",
      "/api/v1/runtime/lifecycle",
      "/api/v1/runtime/chain",
      "/api/v1/runtime/source-scope",
      "/api/v1/runtime/capability-catalog",
      "/api/v1/runtime/analysis",
      "/api/v1/companion/messages",
      "/api/v1/companion/messages/stream",
      "/api/v1/companion/sessions/{session_id}/memory",
      "/api/v1/companion/tasks",
      "/api/v1/runtime/metrics",
      "/api/v1/runtime/telemetry",
      "/api/v1/sessions",
      "/api/v1/sessions/{session_id}",
      "/api/v1/sessions/{session_id}/resume",
      "/api/v1/sessions/{session_id}/suspend",
      "/api/v1/sessions/{session_id}/close",
      "/api/v1/sessions/{session_id}/context",
      "/api/v1/sessions/{session_id}/transfer",
      "/api/v1/attachments",
      "/api/v1/attachments/health",
      "/api/v1/attachments/{product_id}",
      "/api/v1/attachments/{product_id}/health",
      "/api/v1/intents",
      "/api/v1/products/{product_id}/intent-registrations",
      "/api/v1/capabilities",
      "/api/v1/products/{product_id}/capabilities/{capability_id}",
      "/api/v1/intents/dispatch",
      "/api/v1/dispatches",
      "/api/v1/dispatches/{dispatch_id}",
      "/api/v1/dispatches/{dispatch_id}/phases",
      "/api/v1/dispatches/{dispatch_id}/proof"
    ]
  },
