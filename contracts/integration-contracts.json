  "adapter_ports": [
    {
      "port": "ManifestSourceAdapter",
      "python_protocol": "mitra_companion.ports.ManifestSourceAdapter",
      "purpose": "discover product attachment manifests without changing runtime code"
    },
    {
      "port": "TransportAdapter",
      "python_protocol": "mitra_companion.ports.TransportAdapter",
      "purpose": "dispatch versioned envelopes through product-owned transports"
    }
  ],
