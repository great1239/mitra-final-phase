MITRA_COMPANION_ENVIRONMENT=production
MITRA_COMPANION_DATA_ROOT=/data
MITRA_COMPANION_DATABASE_PATH=/data/companion-runtime.db
MITRA_COMPANION_TELEMETRY_LOG_PATH=/data/runtime-telemetry.jsonl
MITRA_COMPANION_MANIFEST_DIRECTORY=/app/contracts/examples
MITRA_COMPANION_HTTP_TIMEOUT_SECONDS=10
MITRA_COMPANION_OTEL_ENABLED=true
MITRA_COMPANION_UVICORN_WORKERS=2
MITRA_COMPANION_FORWARDED_ALLOW_IPS=*
# Leave unset in horizontally scaled deployments so every process/container
# receives a generated unique runtime instance ID.
# MITRA_COMPANION_INSTANCE_ID=mitra-runtime-a
OTEL_SERVICE_NAME=mitra-companion-runtime
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
