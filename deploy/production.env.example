MITRA_COMPANION_ENVIRONMENT=production
MITRA_COMPANION_CONFIG_PROFILE=production
# Optional env-file bootstrap. Environment values override this file.
# MITRA_COMPANION_ENV_FILE=/data/production.env
MITRA_COMPANION_DATA_ROOT=/data
MITRA_COMPANION_DATABASE_PATH=/data/companion-runtime.db
MITRA_COMPANION_SQLITE_SYNCHRONOUS=NORMAL
MITRA_COMPANION_TELEMETRY_LOG_PATH=/data/runtime-telemetry.jsonl
MITRA_COMPANION_LOG_PATH=/data/production-runtime.jsonl
MITRA_COMPANION_LOG_LEVEL=INFO
MITRA_COMPANION_LOG_TO_STDOUT=true
MITRA_COMPANION_MANIFEST_DIRECTORY=/app/contracts/production
MITRA_COMPANION_ALLOW_EXAMPLE_MANIFESTS=false
MITRA_COMPANION_ALLOW_SIMULATED_MANIFESTS=false
MITRA_COMPANION_ALLOW_LOOPBACK_MANIFESTS=false
MITRA_COMPANION_ALLOW_LOCALHOST_MANIFESTS=false
MITRA_COMPANION_REQUIRE_PRODUCTION_BOOTSTRAP_MANIFESTS=true
MITRA_COMPANION_CORS_ORIGINS=https://mitra.blackholeinfiverse.com,https://mitra-live-runtime-sprint.vercel.app,http://localhost:3000,http://127.0.0.1:3000
MITRA_COMPANION_HTTP_TIMEOUT_SECONDS=10
MITRA_COMPANION_OTEL_ENABLED=true
MITRA_COMPANION_UVICORN_WORKERS=1
MITRA_COMPANION_FORWARDED_ALLOW_IPS=*
MITRA_COMPANION_PERSISTENT_RUNTIME_ENABLED=true
MITRA_COMPANION_PERSISTENT_HEARTBEAT_INTERVAL_SECONDS=5
MITRA_COMPANION_PERSISTENT_STALE_AFTER_SECONDS=30
MITRA_COMPANION_PERSISTENT_MAINTENANCE_INTERVAL_SECONDS=60
MITRA_COMPANION_PERSISTENT_TASK_TIMEOUT_SECONDS=300
# Leave unset in horizontally scaled deployments so every process/container
# receives a generated unique runtime instance ID.
# MITRA_COMPANION_INSTANCE_ID=mitra-runtime-a
# Optional mounted secret directory and per-value secret files. Runtime APIs
# only report which secrets are configured; they never return secret values.
# MITRA_COMPANION_SECRETS_DIR=/run/secrets
# MITRA_COMPANION_AI_RESOLVER_URL_FILE=/run/secrets/ai_resolver_url
# MITRA_COMPANION_AI_ANALYSIS_URL_FILE=/run/secrets/ai_analysis_url
# OTEL_EXPORTER_OTLP_ENDPOINT_FILE=/run/secrets/otel_exporter_otlp_endpoint
OTEL_SERVICE_NAME=mitra-companion-runtime
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

# Optional BHIV ecosystem endpoints. Leave unset for isolated local execution;
# configured values are reported only as redacted flags by runtime APIs.
MITRA_BHIV_INTEGRATION_TIMEOUT_SECONDS=10
MITRA_BHIV_INTEGRATION_FAIL_CLOSED=false
# MITRA_BHIV_ASHMIT_BASE_URL_FILE=/run/secrets/bhiv_ashmit_base_url
# MITRA_BHIV_BUCKET_BASE_URL_FILE=/run/secrets/bhiv_bucket_base_url
# MITRA_BHIV_INSIGHTFLOW_INGEST_URL_FILE=/run/secrets/bhiv_insightflow_ingest_url
# MITRA_BHIV_KARMA_BASE_URL_FILE=/run/secrets/bhiv_karma_base_url
# MITRA_BHIV_PRANA_BASE_URL_FILE=/run/secrets/bhiv_prana_base_url
# MITRA_BHIV_BUCKET_PARENT_HASH=replace-with-current-bucket-head-if-latest-hash-is-unavailable
# MITRA_BHIV_KARMA_PREVIOUS_HASH=replace-with-current-karma-last-hash
